# =============================================================================

import sys
import os

PANEL_PATH = '/www/server/panel'

# Run from the panel root so that relative imports inside aaPanel work correctly
os.chdir(PANEL_PATH)

# Prepend plugin and panel class directories to the module search path
sys.path.insert(0, PANEL_PATH + '/plugin/nfs_free')
sys.path.insert(0, PANEL_PATH + '/class')

try:
    import nfs_free_main
    m = nfs_free_main.nfs_free_main()
    m.auto_mount()
except Exception:
    # Silent fail — NFS may not be configured yet at first boot
    pass
